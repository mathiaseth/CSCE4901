rules_version = '2';
// Deploy: from repo root or this folder — firebase deploy --only firestore:rules
// (requires Firebase CLI and `firebase use nutrifit-31b64` or your project id)

service cloud.firestore {
  match /databases/{database}/documents {

    // Public profile + synced metrics for leaderboards (no passwords / onboarding PII).
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // Private account data used to keep onboarding/profile state consistent across devices.
    match /userProfiles/{userId} {
      allow read, create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // `resource` is null when a document does not exist. Rules must allow that case so
    // clients can getDoc() missing friendRequests/friendships without permission errors.
    match /friendRequests/{requestId} {
      allow read: if request.auth != null && (
        resource == null ||
        resource.data.fromUid == request.auth.uid ||
        resource.data.toUid == request.auth.uid
      );
      allow create: if request.auth != null &&
        request.resource.data.fromUid == request.auth.uid &&
        request.resource.data.status == 'pending';
      allow update, delete: if request.auth != null &&
        (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
    }

    match /friendships/{pairId} {
      allow read: if request.auth != null && (
        resource == null ||
        resource.data.uidA == request.auth.uid ||
        resource.data.uidB == request.auth.uid
      );
      allow create: if request.auth != null &&
        (request.resource.data.uidA == request.auth.uid || request.resource.data.uidB == request.auth.uid);
      allow delete: if request.auth != null &&
        (resource.data.uidA == request.auth.uid || resource.data.uidB == request.auth.uid);
      allow update: if false;
    }
  }
}
